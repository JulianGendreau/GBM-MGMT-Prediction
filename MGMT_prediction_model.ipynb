from sklearn.preprocessing import StandardScaler
from sklearn.metrics import roc_auc_score, roc_curve, confusion_matrix

import torch
import torch.nn as nn
import torch.nn.functional as F
from torch.utils.data import Dataset, DataLoader
from tqdm import tqdm

import matplotlib.pyplot as plt


# ============================================================
# Config
# ============================================================
DATA_DIR_T1 = "/Users/juliangendreau/Desktop/mgmt_data_aligned"
LABELS_CSV = "/Users/juliangendreau/Desktop/labels.csv"
DESKTOP = "/Users/juliangendreau/Desktop"

BATCH_SIZE = 4
NUM_EPOCHS = 10
LR = 2e-5
WEIGHT_DECAY = 1e-4
WARMUP_EPOCHS = 5
TARGET_SHAPE = (96, 96, 96)
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")

PATIENCE = 3
BEST_MODEL_PATH = "best_model_mgmt_efficientnet3d.pth"

LABEL_SMOOTHING = 0.0
USE_FOCAL_LOSS = False


# ============================================================
# 3D EfficientNet Components (No MONAI)
# ============================================================
class Conv3dBN(nn.Module):
    def __init__(self, in_ch, out_ch, kernel, stride=1, padding=0):
        super().__init__()
        self.conv = nn.Conv3d(in_ch, out_ch, kernel, stride, padding, bias=False)
        self.bn = nn.BatchNorm3d(out_ch)

    def forward(self, x):
        return F.relu(self.bn(self.conv(x)))


class SqueezeExcite3D(nn.Module):
    def __init__(self, ch, reduction=4):
        super().__init__()
        hidden = max(1, ch // reduction)
        self.fc1 = nn.Conv3d(ch, hidden, 1)
        self.fc2 = nn.Conv3d(hidden, ch, 1)

    def forward(self, x):
        w = F.adaptive_avg_pool3d(x, 1)
        w = F.relu(self.fc1(w))
        w = torch.sigmoid(self.fc2(w))
        return x * w


class MBConv3D(nn.Module):
    def __init__(self, in_ch, out_ch, expand_ratio, stride):
        super().__init__()
        mid = in_ch * expand_ratio
        self.use_res = (stride == 1 and in_ch == out_ch)

        self.expand = nn.Identity()
        if expand_ratio != 1:
            self.expand = Conv3dBN(in_ch, mid, kernel=1)

        self.dw = Conv3dBN(mid, mid, kernel=3, stride=stride, padding=1)
        self.se = SqueezeExcite3D(mid)
        self.project = nn.Conv3d(mid, out_ch, kernel_size=1, bias=False)
        self.bn = nn.BatchNorm3d(out_ch)

    def forward(self, x):
        out = self.expand(x)
        out = self.dw(out)
        out = self.se(out)
        out = self.bn(self.project(out))
        if self.use_res:
            out = out + x
        return F.relu(out)


class EfficientNet3D_B0(nn.Module):
    def __init__(self):
        super().__init__()

        self.stem = Conv3dBN(3, 32, kernel=3, stride=2, padding=1)

        cfg = [
            (1, 16, 1, 1),
            (6, 24, 2, 2),
            (6, 40, 2, 2),
            (6, 80, 3, 2),
            (6, 112, 3, 1),
            (6, 192, 4, 2),
            (6, 320, 1, 1),
        ]

        blocks = []
        in_ch = 32
        for expand, out_ch, repeats, stride in cfg:
            for i in range(repeats):
                s = stride if i == 0 else 1
                blocks.append(MBConv3D(in_ch, out_ch, expand, s))
                in_ch = out_ch

        self.blocks = nn.Sequential(*blocks)
        self.head = Conv3dBN(in_ch, 1280, kernel=1)
        self.pool = nn.AdaptiveAvgPool3d(1)

    def forward(self, x):
        x = self.stem(x)
        x = self.blocks(x)
        x = self.head(x)
        x = self.pool(x)
        return x.flatten(1)  # (B, 1280)


# ============================================================
# Dataset
# ============================================================
class MGMTDataset(Dataset):
    def __init__(self, data_dir_t1, labels_df, mrn_list=None):
        df = labels_df.copy()
        df["MRN"] = df["MRN"].astype(str)

        if mrn_list is not None:
            df = df[df["MRN"].isin(set(map(str, mrn_list)))]

        files_t1 = glob.glob(os.path.join(data_dir_t1, "*.nii.gz"))
        mrns_t1 = {os.path.basename(f).replace(".nii.gz", "") for f in files_t1}
        df = df[df["MRN"].isin(mrns_t1)].reset_index(drop=True)

        self.mrns = df["MRN"].tolist()
        self.labels = df["MGMT"].astype(float).tolist()
        self.covars = df[["Age", "Sex"]].astype(float).values
        self.dir_t1 = data_dir_t1

    def __len__(self):
        return len(self.mrns)

    def load_nifti(self, base, mrn):
        return nib.load(os.path.join(base, f"{mrn}.nii.gz")).get_fdata()

    def preprocess(self, vol):
        vol = vol.astype(np.float32)
        vol = np.nan_to_num(vol)
        vol = (vol - vol.mean()) / (vol.std() + 1e-6)
        vol = torch.from_numpy(vol).unsqueeze(0)
        vol = F.interpolate(
            vol.unsqueeze(0),
            size=TARGET_SHAPE,
            mode="trilinear",
            align_corners=False,
        ).squeeze(0)
        return vol

    def __getitem__(self, idx):
        mrn = self.mrns[idx]
        t1 = self.preprocess(self.load_nifti(self.dir_t1, mrn))
        t1 = t1.repeat(3, 1, 1, 1)

        cov = torch.tensor(self.covars[idx], dtype=torch.float32)
        label = torch.tensor(self.labels[idx], dtype=torch.float32)
        return t1, cov, label


# ============================================================
# MGMT Classifier with EfficientNet3D
# ============================================================
class MGMTEfficientNet3D(nn.Module):
    def __init__(self):
        super().__init__()

        self.backbone = EfficientNet3D_B0()

        for name, param in self.backbone.named_parameters():
            if "stem" in name or "blocks.0" in name:
                param.requires_grad = False

        feat_dim = 1280
        self.fc = nn.Sequential(
            nn.Linear(feat_dim + 2, 256),
            nn.ReLU(),
            nn.Dropout(0.2),
            nn.Linear(256, 64),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(64, 1),
        )

    def forward(self, x1, cov):
        f1 = self.backbone(x1)
        x = torch.cat([f1, cov], dim=1)
        return self.fc(x).squeeze(1)


# ============================================================
# Training / Evaluation
# ============================================================
scaler = torch.cuda.amp.GradScaler(enabled=torch.cuda.is_available())


def train_one_epoch(model, loader, optimizer, epoch, warmup_factor, pos_weight):
    model.train()
    total = 0.0
    criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)

    for t1, cov, label in tqdm(loader, desc=f"Epoch {epoch} - Train", leave=False):
        t1, cov, label = t1.to(DEVICE), cov.to(DEVICE), label.to(DEVICE)

        optimizer.zero_grad()
        with torch.cuda.amp.autocast(enabled=torch.cuda.is_available()):
            logits = model(t1, cov)
            loss = criterion(logits, label)

        scaler.scale(loss).backward()
        scaler.step(optimizer)
        scaler.update()

        total += loss.item()

    return total / len(loader)


def eval_one_epoch(model, loader, epoch):
    model.eval()
    total = 0.0
    criterion = nn.BCEWithLogitsLoss()

    all_labels = []
    all_probs = []

    with torch.no_grad():
        for t1, cov, label in tqdm(loader, desc=f"Epoch {epoch} - Val", leave=False):
            t1, cov, label = t1.to(DEVICE), cov.to(DEVICE), label.to(DEVICE)

            with torch.cuda.amp.autocast(enabled=torch.cuda.is_available()):
                logits = model(t1, cov)
                loss = criterion(logits, label)
                probs = torch.sigmoid(logits)

            total += loss.item()
            all_labels.append(label.cpu().numpy())
            all_probs.append(probs.cpu().numpy())

    all_labels = np.concatenate(all_labels)
    all_probs = np.concatenate(all_probs)
    auc = roc_auc_score(all_labels, all_probs)

    return total / len(loader), auc, all_labels, all_probs


# ============================================================
# Figures
# ============================================================
def plot_roc_curve(labels, probs):
    fpr, tpr, _ = roc_curve(labels, probs)
    auc = roc_auc_score(labels, probs)

    plt.figure(figsize=(8, 6))
    plt.plot(fpr, tpr, label=f"AUC = {auc:.3f}")
    plt.plot([0, 1], [0, 1], "k--")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title("ROC Curve (EfficientNet3D)")
    plt.legend()
    plt.tight_layout()
    plt.savefig(os.path.join(DESKTOP, "mgmt_efficientnet3d_roc_curve.png"), dpi=300)
    plt.close()


def plot_confusion(labels, probs, threshold=0.5):
    preds = (probs >= threshold).astype(int)
    cm = confusion_matrix(labels, preds)

    plt.figure(figsize=(6, 5))
    plt.imshow(cm, cmap="Blues")
    plt.title("Confusion Matrix (EfficientNet3D)")
    plt.colorbar()
    plt.xticks([0, 1], ["Unmethylated", "Methylated"])
    plt.yticks([0, 1], ["Unmethylated", "Methylated"])
    plt.xlabel("Predicted")
    plt.ylabel("True")
    plt.tight_layout()
    plt.savefig(os.path.join(DESKTOP, "mgmt_efficientnet3d_confusion_matrix.png"), dpi=300)
    plt.close()


def plot_prob_hist(probs):
    plt.figure(figsize=(8, 6))
    plt.hist(probs, bins=20, color="steelblue", edgecolor="black")
    plt.title("Predicted MGMT Probabilities (EfficientNet3D)")
    plt.xlabel("Probability")
    plt.ylabel("Count")
    plt.tight_layout()
    plt.savefig(os.path.join(DESKTOP, "mgmt_efficientnet3d_probability_histogram.png"), dpi=300)
    plt.close()


# ============================================================
# Main
# ============================================================
def main():
    labels = pd.read_csv(LABELS_CSV)
    labels = labels.replace(["", " ", "NaN", "nan"], np.nan)

    for col in ["MGMT", "Age", "Sex"]:
        labels[col] = pd.to_numeric(labels[col], errors="coerce")

    labels = labels.dropna()

    scaler_cov = StandardScaler()
    labels[["Age", "Sex"]] = scaler_cov.fit_transform(labels[["Age", "Sex"]])

    train_mrns, val_mrns = train_test_split(labels["MRN"], test_size=0.2, random_state=42)

    train_labels = labels[labels["MRN"].isin(train_mrns)]
    pos = train_labels["MGMT"].sum()
    neg = len(train_labels) - pos
    pos_weight = torch.tensor([neg / pos]).to(DEVICE)

    train_ds = MGMTDataset(DATA_DIR_T1, labels, train_mrns)
    val_ds = MGMTDataset(DATA_DIR_T1, labels, val_mrns)

    train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True)
    val_loader = DataLoader(val_ds, batch_size=BATCH_SIZE, shuffle=False)

    model = MGMTEfficientNet3D().to(DEVICE)

    optimizer = torch.optim.AdamW(
        filter(lambda p: p.requires_grad, model.parameters()),
        lr=LR,
        weight_decay=WEIGHT_DECAY,
    )
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=NUM_EPOCHS)

    best_auc = -np.inf
    patience = 0

    for epoch in range(1, NUM_EPOCHS + 1):
        warmup_factor = min(1.0, epoch / WARMUP_EPOCHS)
        for g in optimizer.param_groups:
            g["lr"] = LR * warmup_factor

        train_loss = train_one_epoch(model, train_loader, optimizer, epoch, warmup_factor, pos_weight)
        val_loss, auc, labels_val, probs_val = eval_one_epoch(model, val_loader, epoch)

        print(f"\nEpoch {epoch}")
        print(f"Train Loss {train_loss:.4f}")
        print(f"Val Loss {val_loss:.4f} | AUC {auc:.4f}")

        if auc > best_auc:
            best_auc = auc
            patience = 0
            torch.save(model.state_dict(), BEST_MODEL_PATH)
            print(f"New best model saved (AUC={best_auc:.4f})")
        else:
            patience += 1
            print(f"No improvement for {patience} epoch(s).")
            if patience >= PATIENCE:
                print("Early stopping triggered.")
                break

        scheduler.step()

    print("\nReloading best model...")
    model.load_state_dict(torch.load(BEST_MODEL_PATH, map_location=DEVICE))
    model.eval()

    _, _, labels_val, probs_val = eval_one_epoch(model, val_loader, epoch=0)

    plot_roc_curve(labels_val, probs_val)
    plot_confusion(labels_val, probs_val)
    plot_prob_hist(probs_val)

    print(f"MGMT classification (EfficientNet3D) complete. Best AUC: {best_auc:.4f}")


if __name__ == "__main__":
    main()

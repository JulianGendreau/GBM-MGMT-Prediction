import os
import numpy as np
import pydicom
import nibabel as nib
from scipy.ndimage import zoom
from nibabel.orientations import (
    io_orientation, axcodes2ornt, ornt_transform,
    apply_orientation, inv_ornt_aff
)

# ---------------------------------------------------------
# Input and Output Paths
# ---------------------------------------------------------
INPUT_ROOT = "/Users/juliangendreau/Desktop/mgmt_data_supplement"
OUTPUT_ROOT = "/Users/juliangendreau/Desktop/mgmt_data_supplement_fixed"

T1_OUT = os.path.join(OUTPUT_ROOT, "T1")
T2_OUT = os.path.join(OUTPUT_ROOT, "T2")

os.makedirs(T1_OUT, exist_ok=True)
os.makedirs(T2_OUT, exist_ok=True)

TARGET_SPACING = np.array([1.0, 1.0, 1.0])


# ---------------------------------------------------------
# Helpers
# ---------------------------------------------------------
def detect_modality(ds):
    """Return 'T1', 'T2', or None based on DICOM metadata."""
    desc = (ds.get("SeriesDescription", "") + " " + ds.get("ProtocolName", "")).lower()

    if "t1" in desc:
        return "T1"
    if "t2" in desc:
        return "T2"

    return None


def collect_dicoms_recursive(folder):
    """Walk all subfolders and collect DICOM files."""
    dicoms = []
    for root, _, files in os.walk(folder):
        for f in files:
            if f.lower().endswith(".dcm"):
                dicoms.append(os.path.join(root, f))
    return dicoms


def load_dicom_series(folder):
    """Load all valid DICOM slices and group by modality."""
    series = {"T1": [], "T2": []}

    dicom_files = collect_dicoms_recursive(folder)

    for path in dicom_files:
        try:
            ds = pydicom.dcmread(path)
        except:
            continue

        if not hasattr(ds, "PixelData") or not hasattr(ds, "ImagePositionPatient"):
            continue

        modality = detect_modality(ds)
        if modality:
            series[modality].append(ds)

    return series


def build_volume(slices):
    """Convert sorted DICOM slices into a 3D volume + affine."""
    if len(slices) < 2:
        return None, None

    slices.sort(key=lambda s: float(s.ImagePositionPatient[2]))

    try:
        vol = np.stack([s.pixel_array for s in slices], axis=-1).astype(np.float32)
    except:
        return None, None

    try:
        spacing_xy = np.array(slices[0].PixelSpacing, dtype=float)
        spacing_z = float(
            slices[1].ImagePositionPatient[2] - slices[0].ImagePositionPatient[2]
        )
        spacing = np.array([spacing_xy[0], spacing_xy[1], abs(spacing_z)])
    except:
        return None, None

    affine = np.eye(4)
    affine[0, 0], affine[1, 1], affine[2, 2] = spacing

    return vol, affine


def fix_orientation_safe(vol, affine):
    try:
        cur = io_orientation(affine)
        tgt = axcodes2ornt(("R", "A", "S"))
        transform = ornt_transform(cur, tgt)

        new_vol = apply_orientation(vol, transform)
        new_affine = affine @ inv_ornt_aff(transform, vol.shape)
        return new_vol, new_affine
    except:
        fallback_affine = np.eye(4)
        spacing = np.abs(np.diag(affine))[:3]
        fallback_affine[:3, :3] = np.diag(spacing)
        return vol, fallback_affine


def resample_to_spacing(vol, affine, target_spacing):
    try:
        current_spacing = np.abs(np.diag(affine))[:3]
        zoom_factors = current_spacing / target_spacing
        new_vol = zoom(vol, zoom_factors, order=3)

        new_affine = affine.copy()
        new_affine[:3, :3] = np.diag(target_spacing)
        return new_vol, new_affine
    except:
        return None, None


# ---------------------------------------------------------
# Main processing
# ---------------------------------------------------------
def process_patient(patient_folder, mrn):
    series = load_dicom_series(patient_folder)

    for modality in ["T1", "T2"]:
        slices = series[modality]
        if len(slices) < 2:
            print(f"Skipping {mrn} {modality}: insufficient slices")
            continue

        vol, affine = build_volume(slices)
        if vol is None:
            print(f"Skipping {mrn} {modality}: failed to build volume")
            continue

        vol, affine = fix_orientation_safe(vol, affine)
        vol, affine = resample_to_spacing(vol, affine, TARGET_SPACING)

        if vol is None:
            print(f"Skipping {mrn} {modality}: resampling failed")
            continue

        affine[:3, 3] = 0

        out_dir = T1_OUT if modality == "T1" else T2_OUT
        out_path = os.path.join(out_dir, f"{mrn}.nii.gz")

        nib.Nifti1Image(vol, affine).to_filename(out_path)
        print(f"Saved {modality}: {out_path}")


# ---------------------------------------------------------
# Walk input directory
# ---------------------------------------------------------
for mrn in os.listdir(INPUT_ROOT):
    patient_path = os.path.join(INPUT_ROOT, mrn)
    if os.path.isdir(patient_path):
        process_patient(patient_path, mrn)
